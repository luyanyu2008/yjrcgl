<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<title>云锦长安 · 人才库管理后台</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;500;600;700&family=Cormorant+Garamond:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #2a2522;
    --ink-soft: #5a4f49;
    --ink-light: #8b7e74;
    --paper: #f5efe6;
    --paper-warm: #ebe3d4;
    --bg: #faf6ef;
    --rouge: #a02c2c;
    --rouge-deep: #7a1f1f;
    --gold: #b8935a;
    --line: #d9cdb8;
    --line-soft: #e8dfd0;
    --white: #ffffff;
    --green: #5a7d4f;
    --orange: #c97a3c;
    --shadow: 0 4px 16px rgba(42, 37, 34, 0.06);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: var(--bg);
    color: var(--ink);
    font-family: 'Noto Serif SC', sans-serif;
    font-size: 14px;
    min-height: 100vh;
    display: flex;
  }

  /* 侧边栏 */
  .sidebar {
    width: 220px; background: var(--ink); color: var(--paper);
    padding: 26px 0; min-height: 100vh; flex-shrink: 0;
    position: sticky; top: 0; height: 100vh;
  }
  .logo {
    padding: 0 26px 26px; border-bottom: 1px solid rgba(245,239,230,0.1);
    margin-bottom: 14px;
  }
  .logo-cn { font-size: 22px; letter-spacing: 6px; font-weight: 600; margin-bottom: 4px; }
  .logo-en { font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 12px; color: var(--gold); letter-spacing: 2px; }
  .nav { padding: 6px 0; }
  .nav-section { padding: 12px 26px 8px; font-size: 11px; color: var(--ink-light); letter-spacing: 3px; }
  .nav-item {
    padding: 12px 26px; cursor: pointer; transition: all 0.2s;
    display: flex; align-items: center; gap: 12px;
    font-size: 14px; letter-spacing: 2px;
    border-left: 3px solid transparent;
  }
  .nav-item:hover { background: rgba(245,239,230,0.06); }
  .nav-item.active { background: rgba(160,44,44,0.2); border-left-color: var(--rouge); color: white; }
  .nav-item .count {
    margin-left: auto; background: rgba(184,147,90,0.25);
    color: var(--gold); padding: 1px 8px; border-radius: 10px;
    font-size: 11px; font-family: 'Cormorant Garamond', serif;
  }

  /* 主区 */
  .main { flex: 1; padding: 30px 36px; min-width: 0; }
  .page-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
  .page-title { font-size: 24px; font-weight: 600; letter-spacing: 4px; }
  .page-title small { color: var(--ink-light); font-size: 13px; font-weight: 400; margin-left: 12px; letter-spacing: 1px; }
  .actions { display: flex; gap: 10px; }
  .btn {
    padding: 8px 16px; border: 1px solid var(--line); background: var(--white);
    cursor: pointer; font-family: inherit; font-size: 13px; letter-spacing: 2px;
    transition: all 0.2s; color: var(--ink);
  }
  .btn:hover { border-color: var(--rouge); color: var(--rouge); }
  .btn-primary { background: var(--rouge); color: white; border-color: var(--rouge); }
  .btn-primary:hover { background: var(--rouge-deep); color: white; }
  .btn-dark { background: var(--ink); color: white; border-color: var(--ink); }
  .btn-dark:hover { background: #000; color: white; }
  .btn-ai {
    background: linear-gradient(135deg, #b8935a 0%, #a02c2c 100%);
    color: white !important; border: none;
    box-shadow: 0 2px 8px rgba(160,44,44,0.25);
    display: inline-flex; align-items: center;
  }
  .btn-ai:hover {
    box-shadow: 0 4px 12px rgba(160,44,44,0.35);
    transform: translateY(-1px); color: white !important;
  }
  .nav-item-ai {
    background: linear-gradient(90deg, rgba(184,147,90,0.18), rgba(160,44,44,0.12));
    color: white !important; border-left: 3px solid var(--gold) !important;
    font-weight: 500; display: flex; align-items: center; gap: 10px;
  }
  .nav-item-ai:hover { background: linear-gradient(90deg, rgba(184,147,90,0.3), rgba(160,44,44,0.2)) !important; }

  /* ===== AI 智能录入页 ===== */
  .ai-hero {
    background: linear-gradient(135deg, #2a2522 0%, #5a4f49 100%);
    color: var(--paper); padding: 28px 32px;
    border-left: 4px solid var(--gold);
    margin-bottom: 24px; position: relative; overflow: hidden;
  }
  .ai-hero::after {
    content: 'AI'; position: absolute; right: -10px; top: -20px;
    font-family: 'Cormorant Garamond', serif; font-size: 140px;
    color: rgba(184,147,90,0.1); font-weight: 700; letter-spacing: -8px;
    pointer-events: none;
  }
  .ai-hero h2 { font-size: 22px; letter-spacing: 4px; margin-bottom: 8px; position: relative; z-index: 1; }
  .ai-hero p { font-size: 13px; opacity: 0.85; line-height: 1.8; position: relative; z-index: 1; }

  .ai-tabs { display: flex; gap: 0; margin-bottom: 18px; border-bottom: 1px solid var(--line); }
  .ai-tab {
    padding: 12px 24px; cursor: pointer; font-size: 14px;
    color: var(--ink-soft); letter-spacing: 2px;
    border-bottom: 2px solid transparent; transition: all 0.2s;
  }
  .ai-tab.active { color: var(--rouge); border-bottom-color: var(--rouge); font-weight: 500; }

  .ai-input-area {
    background: white; padding: 24px; border: 1px solid var(--line-soft);
    margin-bottom: 16px;
  }
  .ai-textarea {
    width: 100%; min-height: 220px; padding: 14px;
    border: 1px solid var(--line); background: var(--bg);
    font-family: inherit; font-size: 13px; line-height: 1.8;
    resize: vertical; color: var(--ink);
  }
  .ai-textarea:focus { outline: none; border-color: var(--rouge); background: white; }

  .ai-image-drop {
    border: 2px dashed var(--line); background: var(--paper);
    padding: 40px 20px; text-align: center; cursor: pointer;
    transition: all 0.2s;
  }
  .ai-image-drop:hover, .ai-image-drop.dragover {
    border-color: var(--rouge); background: rgba(160,44,44,0.03);
  }
  .ai-image-drop .icon { font-size: 36px; color: var(--ink-light); margin-bottom: 10px; }
  .ai-image-drop .text { font-size: 13px; color: var(--ink-soft); }
  .ai-image-list { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-top: 14px; }
  .ai-image-list .pic {
    aspect-ratio: 1; position: relative; overflow: hidden;
    border: 1px solid var(--line);
  }
  .ai-image-list .pic img { width: 100%; height: 100%; object-fit: cover; }
  .ai-image-list .pic .del {
    position: absolute; top: 4px; right: 4px; width: 22px; height: 22px;
    background: rgba(42,37,34,0.7); color: white; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; font-size: 12px;
  }

  .ai-action-bar { display: flex; gap: 10px; margin-top: 18px; align-items: center; }
  .ai-action-bar .hint { color: var(--ink-light); font-size: 12px; }

  .ai-loading {
    text-align: center; padding: 60px 20px; color: var(--ink-soft);
  }
  .ai-loading .spinner {
    display: inline-block; width: 32px; height: 32px;
    border: 3px solid var(--line); border-top-color: var(--rouge);
    border-radius: 50%; animation: spin 0.8s linear infinite;
    margin-bottom: 14px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  .ai-result-card {
    background: white; border: 1px solid var(--line-soft);
    margin-bottom: 16px; overflow: hidden;
  }
  .ai-result-head {
    padding: 14px 20px; background: var(--paper);
    display: flex; justify-content: space-between; align-items: center;
    border-bottom: 1px solid var(--line-soft);
  }
  .ai-result-head .name {
    font-size: 16px; font-weight: 500; letter-spacing: 2px;
  }
  .ai-result-head .role {
    padding: 3px 10px; background: var(--rouge); color: white;
    font-size: 11px; letter-spacing: 1px;
  }
  .ai-result-body { padding: 16px 20px; }
  .ai-field-row {
    display: grid; grid-template-columns: 100px 1fr 80px; gap: 12px;
    padding: 8px 0; border-bottom: 1px dashed var(--line-soft);
    align-items: center;
  }
  .ai-field-row:last-child { border-bottom: none; }
  .ai-field-row .k { color: var(--ink-light); font-size: 12px; letter-spacing: 1px; }
  .ai-field-row input, .ai-field-row textarea {
    padding: 6px 10px; border: 1px solid var(--line);
    font-family: inherit; font-size: 13px; background: var(--bg);
    width: 100%;
  }
  .ai-field-row input:focus, .ai-field-row textarea:focus { outline: none; border-color: var(--rouge); background: white; }
  .ai-field-row.low-conf input, .ai-field-row.low-conf textarea {
    border-color: var(--orange); background: rgba(201,122,60,0.05);
  }
  .confidence-tag {
    font-size: 10px; padding: 2px 6px; letter-spacing: 1px;
    text-align: center; border-radius: 2px;
  }
  .confidence-tag.high { background: rgba(90,125,79,0.15); color: var(--green); }
  .confidence-tag.medium { background: rgba(184,147,90,0.15); color: var(--gold); }
  .confidence-tag.low { background: rgba(201,122,60,0.15); color: var(--orange); }

  .ai-section-title {
    font-size: 11px; letter-spacing: 3px; color: var(--rouge);
    padding: 12px 20px 6px; background: rgba(160,44,44,0.04);
    border-top: 1px solid var(--line-soft);
  }
  .ai-merge-badge {
    display: inline-block; padding: 2px 8px; background: var(--gold);
    color: white; font-size: 10px; letter-spacing: 1px;
    margin-left: 8px;
  }
  .ai-tip {
    padding: 10px 14px; background: rgba(184,147,90,0.08);
    border-left: 3px solid var(--gold); font-size: 12px;
    color: var(--ink-soft); margin-bottom: 14px;
  }
  .ai-history-item {
    padding: 10px 14px; background: var(--paper); margin-bottom: 8px;
    font-size: 12px; color: var(--ink-soft);
    border-left: 3px solid var(--ink-light);
  }
  .ai-history-item .h-date { font-family: 'Cormorant Garamond', serif; color: var(--ink); }
  .ai-history-item .h-text {
    margin-top: 6px; padding: 8px 10px; background: white;
    max-height: 80px; overflow: hidden; line-height: 1.7;
    border-radius: 2px; font-size: 11px;
  }

  /* 顶部数据看板 */
  .dashboard {
    display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px; margin-bottom: 24px;
  }
  .stat-card {
    background: var(--white); border: 1px solid var(--line-soft);
    padding: 18px 20px; position: relative; overflow: hidden;
  }
  .stat-card::after {
    content: ''; position: absolute; top: 0; right: 0; width: 60px; height: 60px;
    background: var(--paper-warm); border-radius: 50%;
    transform: translate(20px,-20px); opacity: 0.6;
  }
  .stat-label { font-size: 12px; color: var(--ink-light); letter-spacing: 2px; margin-bottom: 8px; }
  .stat-value {
    font-family: 'Cormorant Garamond', serif; font-size: 32px; font-weight: 400;
    color: var(--ink); line-height: 1; position: relative; z-index: 1;
  }
  .stat-value .unit { font-size: 14px; color: var(--ink-light); margin-left: 4px; }

  /* 筛选区 */
  .filters {
    background: var(--white); padding: 18px 20px; margin-bottom: 18px;
    border: 1px solid var(--line-soft); display: flex; flex-wrap: wrap; gap: 12px; align-items: center;
  }
  .filter-item { display: flex; align-items: center; gap: 6px; }
  .filter-item label { font-size: 12px; color: var(--ink-soft); letter-spacing: 1px; }
  .filter-item select, .filter-item input {
    padding: 6px 10px; border: 1px solid var(--line); background: var(--bg);
    font-family: inherit; font-size: 13px; color: var(--ink); min-width: 100px;
  }
  .filter-item input { min-width: 160px; }
  .filter-item select:focus, .filter-item input:focus { outline: none; border-color: var(--rouge); }

  /* 表格 */
  .table-wrap { background: var(--white); border: 1px solid var(--line-soft); overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; min-width: 1100px; }
  th {
    text-align: left; padding: 14px 14px; background: var(--paper);
    font-weight: 500; letter-spacing: 1px; color: var(--ink-soft);
    border-bottom: 1px solid var(--line); font-size: 12px;
    cursor: pointer; user-select: none;
  }
  th:hover { color: var(--rouge); }
  td { padding: 14px; border-bottom: 1px solid var(--line-soft); vertical-align: middle; }
  tr:hover td { background: #fdfaf3; }
  .avatar {
    width: 36px; height: 36px; border-radius: 50%; object-fit: cover;
    background: var(--paper-warm); display: inline-flex; align-items: center; justify-content: center;
    color: var(--ink-soft); font-size: 13px;
  }
  .name-cell { display: flex; align-items: center; gap: 12px; }
  .name-info { display: flex; flex-direction: column; }
  .name-info .name { font-weight: 500; color: var(--ink); }
  .name-info .phone { font-size: 11px; color: var(--ink-light); font-family: 'Cormorant Garamond', serif; }

  /* 评级徽章 */
  .rating {
    display: inline-block; width: 26px; height: 26px; line-height: 24px;
    text-align: center; border-radius: 50%; font-weight: 600; font-size: 12px;
    font-family: 'Cormorant Garamond', serif;
  }
  .rating-S { background: var(--rouge); color: white; }
  .rating-A { background: var(--gold); color: white; }
  .rating-B { background: var(--ink-light); color: white; }
  .rating-C { background: var(--line); color: var(--ink-soft); }
  .rating-none { background: transparent; border: 1px dashed var(--line); color: var(--ink-light); }

  .status-tag {
    display: inline-block; padding: 3px 10px; font-size: 11px;
    border: 1px solid; letter-spacing: 1px;
  }
  .status-default { color: var(--ink-soft); border-color: var(--line); }
  .status-good { color: var(--green); border-color: var(--green); background: rgba(90,125,79,0.05); }
  .status-warn { color: var(--orange); border-color: var(--orange); background: rgba(201,122,60,0.05); }
  .status-bad { color: var(--rouge); border-color: var(--rouge); background: rgba(160,44,44,0.05); }
  .status-block { background: var(--ink); color: white; border-color: var(--ink); }

  .role-badge {
    display: inline-block; padding: 2px 8px; font-size: 11px;
    background: var(--paper); color: var(--ink-soft); letter-spacing: 1px;
  }

  /* 抽屉 */
  .drawer-mask {
    position: fixed; inset: 0; background: rgba(42,37,34,0.4); z-index: 99;
    display: none; opacity: 0; transition: opacity 0.3s;
  }
  .drawer-mask.show { display: block; opacity: 1; }
  .drawer {
    position: fixed; top: 0; right: -780px; width: 780px; max-width: 95vw;
    height: 100vh; background: var(--bg); z-index: 100;
    transition: right 0.35s cubic-bezier(0.2, 0.8, 0.2, 1);
    overflow-y: auto; box-shadow: -10px 0 40px rgba(0,0,0,0.1);
  }
  .drawer.show { right: 0; }
  .drawer-head {
    padding: 22px 30px; border-bottom: 1px solid var(--line);
    display: flex; justify-content: space-between; align-items: center;
    background: var(--white); position: sticky; top: 0; z-index: 2;
  }
  .drawer-head h2 { font-size: 18px; letter-spacing: 4px; }
  .drawer-close { cursor: pointer; font-size: 22px; color: var(--ink-light); }
  .drawer-close:hover { color: var(--rouge); }
  .drawer-body { padding: 24px 30px 60px; }

  .panel {
    background: var(--white); border: 1px solid var(--line-soft);
    padding: 20px 24px; margin-bottom: 16px;
  }
  .panel h3 {
    font-size: 14px; letter-spacing: 4px; margin-bottom: 14px;
    color: var(--rouge); padding-bottom: 10px; border-bottom: 1px solid var(--line-soft);
    display: flex; align-items: center; justify-content: space-between;
  }
  .panel h3 small { font-size: 11px; color: var(--ink-light); letter-spacing: 1px; font-weight: 400; }

  /* 信息行 */
  .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px 24px; }
  .info-row { display: flex; padding: 6px 0; font-size: 13px; }
  .info-row .k { width: 90px; color: var(--ink-light); flex-shrink: 0; }
  .info-row .v { color: var(--ink); flex: 1; word-break: break-all; }

  .styles-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 4px; }
  .style-tag {
    display: inline-block; padding: 2px 9px; background: var(--paper-warm);
    color: var(--ink-soft); font-size: 11px; letter-spacing: 1px;
  }

  /* 作品集 */
  .gallery { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
  .gallery img {
    width: 100%; aspect-ratio: 1; object-fit: cover; cursor: pointer;
    border: 1px solid var(--line-soft); transition: transform 0.2s;
  }
  .gallery img:hover { transform: scale(1.03); }

  /* 评分表单 */
  .form-row { display: flex; align-items: center; margin-bottom: 14px; gap: 14px; }
  .form-row label { width: 100px; font-size: 13px; color: var(--ink-soft); flex-shrink: 0; }
  .form-row select, .form-row input, .form-row textarea {
    flex: 1; padding: 7px 10px; border: 1px solid var(--line);
    font-family: inherit; font-size: 13px; background: var(--bg);
  }
  .form-row textarea { min-height: 60px; resize: vertical; }
  .form-row select:focus, .form-row input:focus, .form-row textarea:focus { outline: none; border-color: var(--rouge); }
  .form-row .stars {
    display: flex; gap: 4px;
  }
  .star {
    width: 24px; height: 24px; cursor: pointer; color: var(--line);
    font-size: 20px; line-height: 24px; user-select: none;
  }
  .star.on { color: var(--gold); }

  /* 客诉记录列表 */
  .complaint-list { display: flex; flex-direction: column; gap: 10px; }
  .complaint-item {
    padding: 12px 14px; background: var(--paper); border-left: 3px solid var(--orange);
    font-size: 13px;
  }
  .complaint-item .ch { display: flex; justify-content: space-between; margin-bottom: 4px; font-size: 12px; color: var(--ink-light); }
  .complaint-item .cb { color: var(--ink); }
  .empty {
    text-align: center; color: var(--ink-light); padding: 20px;
    font-size: 13px; letter-spacing: 1px;
  }

  /* 标签 chip */
  .flag-chip {
    display: inline-block; padding: 4px 10px; font-size: 12px;
    border: 1px solid var(--line); background: var(--white);
    color: var(--ink-soft); cursor: pointer; user-select: none;
    transition: all 0.2s; border-radius: 14px;
  }
  .flag-chip:hover { border-color: var(--rouge); color: var(--rouge); }
  .flag-chip.on { background: var(--rouge); color: white; border-color: var(--rouge); }

  /* 记录列表项 */
  .record-item {
    padding: 12px 14px; background: var(--paper); margin-bottom: 8px;
    font-size: 13px; display: flex; align-items: flex-start; gap: 12px;
  }
  .record-item .r-date {
    width: 80px; font-family: 'Cormorant Garamond', serif; color: var(--ink-light); flex-shrink: 0;
  }
  .record-item .r-body { flex: 1; }
  .record-item .r-body .r-title { font-weight: 500; margin-bottom: 4px; }
  .record-item .r-body .r-detail { color: var(--ink-soft); font-size: 12px; line-height: 1.7; }
  .record-item .r-actions { display: flex; gap: 8px; }
  .record-item .r-del { cursor: pointer; color: var(--rouge); font-size: 11px; }
  .record-item.unreplied { border-left: 3px solid var(--orange); background: rgba(201,122,60,0.04); }
  .record-item.unsettled { border-left: 3px solid var(--rouge); background: rgba(160,44,44,0.04); }
  .record-item.settled { border-left: 3px solid var(--green); }

  /* 视频卡片 */
  .video-gallery { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
  .video-card {
    position: relative; aspect-ratio: 1; cursor: pointer;
    background: black; overflow: hidden; border: 1px solid var(--line-soft);
  }
  .video-card video { width: 100%; height: 100%; object-fit: cover; }
  .video-card::after {
    content: '▶'; position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    color: white; font-size: 32px; text-shadow: 0 2px 8px rgba(0,0,0,0.5);
    pointer-events: none;
  }
  .video-card .v-name {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 6px 10px; background: rgba(0,0,0,0.5); color: white;
    font-size: 11px; pointer-events: none;
  }

  /* 时间线 */
  .timeline { position: relative; padding-left: 24px; }
  .timeline::before {
    content: ''; position: absolute; left: 6px; top: 8px; bottom: 8px;
    width: 1px; background: var(--line);
  }
  .timeline-item { position: relative; padding-bottom: 16px; }
  .timeline-item::before {
    content: ''; position: absolute; left: -22px; top: 6px;
    width: 11px; height: 11px; border-radius: 50%;
    background: var(--rouge); border: 2px solid var(--bg);
  }
  .timeline-item.is-contact::before { background: var(--gold); }
  .timeline-item.is-payment::before { background: var(--green); }
  .timeline-item.is-complaint::before { background: var(--orange); }
  .timeline-item.is-praise::before { background: var(--green); }
  .timeline-item .ti-head {
    font-size: 12px; color: var(--ink-light); margin-bottom: 4px;
    font-family: 'Cormorant Garamond', serif;
  }
  .timeline-item .ti-body { font-size: 13px; color: var(--ink); }
  .timeline-item .ti-tag {
    display: inline-block; padding: 1px 6px; font-size: 10px;
    margin-right: 6px; letter-spacing: 1px;
    background: var(--paper-warm); color: var(--ink-soft);
  }

  /* 档期 */
