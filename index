  if (!date || !task) { alert('请填写日期和任务'); return; }

  if (!t.dispatch_records) t.dispatch_records = [];
  t.dispatch_records.push({ date, task, customer, fee, note });
  t.work_count = (t.work_count || 0) + 1;

  // 自动占用档期
  if (!t.calendar_busy) t.calendar_busy = [];
  if (!t.calendar_busy.includes(date)) t.calendar_busy.push(date);

  // 自动创建未结结算
  if (createPayment && fee) {
    if (!t.payment_records) t.payment_records = [];
    t.payment_records.push({ date, project: task, amount: Number(fee) || 0, settled: false, note });
  }

  await updateTalent(t);
  closeModal();
  renderDrawerBody();
  toast('派单成功 · 档期已占用');
}

