  if (role === 'dress') return ['待复试', '已录用', '兼职合作', '已离职', '拉黑'];
  if (role === 'photo') return ['待复试', '长期签约', '偶尔合作', '已终止', '拉黑'];
  if (role === 'retouch') return ['待复试', '长期合作', '偶尔接单', '已淘汰', '拉黑'];
  if (role === 'model') return ['待试拍', '常用模特', '互免合作', '签约', '已淘汰', '拉黑'];
  if (role === 'anchor') return ['待试播', '在职', '兼职合作', '已离职', '拉黑'];
