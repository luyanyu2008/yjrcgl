function switchAIMode(mode) {
  aiInputMode = mode;
  aiParseResults = [];
  renderAIImport();
}

async function handleAIImageSelect(e) {
  for (const f of e.target.files) {
    if (f.size > 4 * 1024 * 1024) {
      alert(`图片「${f.name}」超过 4MB,会影响解析速度,已跳过`);
      continue;
    }
    const compressed = await compressImage(f);
    aiImageList.push(compressed);
  }
  renderAIImport();
}

async function handleAIImageDrop(e) {
  for (const f of e.dataTransfer.files) {
    if (!f.type.startsWith('image/')) continue;
    if (f.size > 4 * 1024 * 1024) {
      alert(`图片「${f.name}」超过 4MB,已跳过`);
      continue;
    }
    const compressed = await compressImage(f);
    aiImageList.push(compressed);
  }
  renderAIImport();
}

function compressImage(file) {
  return new Promise((resolve) => {
    const reader = new FileReader();
    reader.onload = e => {
      const img = new Image();
      img.onload = () => {
        const canvas = document.createElement('canvas');
        const scale = Math.min(1, 1200 / img.width);
        canvas.width = img.width * scale;
        canvas.height = img.height * scale;
        canvas.getContext('2d').drawImage(img, 0, 0, canvas.width, canvas.height);
        const dataUrl = canvas.toDataURL('image/jpeg', 0.85);
        // 取出 base64 部分(去掉 data:image/jpeg;base64, 前缀)
        const base64 = dataUrl.split(',')[1];
        resolve({ url: dataUrl, base64, mediaType: 'image/jpeg' });
      };
      img.src = e.target.result;
    };
    reader.readAsDataURL(file);
  });
}

