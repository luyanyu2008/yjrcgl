/* ============== 档期 ============== */
let calendarMonth = new Date();
function renderCalendar(t) {
  const y = calendarMonth.getFullYear();
  const m = calendarMonth.getMonth();
  const first = new Date(y, m, 1);
  const last = new Date(y, m+1, 0);
  const startDay = first.getDay();
  const busy = t.calendar_busy || [];
  const free = t.calendar_free || [];
  const todayStr = new Date().toISOString().slice(0,10);

  let html = `
    <div class="cal-controls">
      <button class="btn" onclick="changeMonth(-1)">‹</button>
      <span class="month">${y} 年 ${m+1} 月</span>
      <button class="btn" onclick="changeMonth(1)">›</button>
    </div>
    <div class="calendar">
      ${['日','一','二','三','四','五','六'].map(d => `<div class="cal-head">${d}</div>`).join('')}
      ${Array(startDay).fill('<div></div>').join('')}
  `;
  for (let d = 1; d <= last.getDate(); d++) {
    const dateStr = `${y}-${String(m+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const isBusy = busy.includes(dateStr);
    const isFree = free.includes(dateStr);
    const isToday = dateStr === todayStr;
    html += `
      <div class="cal-day ${isBusy?'busy':isFree?'free':''}" onclick="toggleDay('${dateStr}')"
           style="${isToday?'box-shadow:inset 0 0 0 2px var(--gold);':''}">
        <div class="d-num">${d}</div>
        ${isBusy ? '<div class="d-tag">占</div>' : isFree ? '<div class="d-tag">空</div>' : ''}
      </div>
    `;
  }
  html += `</div>
    <div class="cal-legend">
      <span><span class="dot" style="background:var(--rouge);"></span>已占用</span>
      <span><span class="dot" style="background:rgba(90,125,79,0.3);"></span>明确空闲</span>
      <span>点击日期切换状态</span>
    </div>
  `;
  return html;
}

function changeMonth(delta) {
  calendarMonth.setMonth(calendarMonth.getMonth() + delta);
  renderDrawerBody();
}

async function toggleDay(dateStr) {
  const t = currentTalent;
  if (!t.calendar_busy) t.calendar_busy = [];
  if (!t.calendar_free) t.calendar_free = [];
  const inBusy = t.calendar_busy.includes(dateStr);
  const inFree = t.calendar_free.includes(dateStr);
  if (!inBusy && !inFree) {
    t.calendar_busy.push(dateStr);
  } else if (inBusy) {
    t.calendar_busy = t.calendar_busy.filter(d => d !== dateStr);
    t.calendar_free.push(dateStr);
  } else {
    t.calendar_free = t.calendar_free.filter(d => d !== dateStr);
  }
  await updateTalent(t);
  renderDrawerBody();
}

