function countUnsettled(all) {
  let count = 0, amount = 0;
  all.forEach(t => {
    (t.payment_records || []).forEach(p => {
      if (!p.settled && Number(p.amount) > 0) {
        count++;
        amount += Number(p.amount) || 0;
      }
    });
  });
  return { count, amount };
}

function renderWeekendList(all) {
  const now = new Date();
  const dow = now.getDay();
  const sat = new Date(now); sat.setDate(now.getDate() + ((6 - dow + 7) % 7 || 7));
  const sun = new Date(sat); sun.setDate(sat.getDate() + 1);
  const fmt = d => d.toISOString().slice(0,10);
  const candidates = all.filter(t => {
    const busy = t.calendar_busy || [];
    const r = t.tech_rating || t.quality_rating || t.service_rating || '';
    return !busy.includes(fmt(sat)) && !busy.includes(fmt(sun)) && ['S','A'].includes(r) && t.blacklist_mark === '正常';
  }).slice(0, 8);
  if (!candidates.length) return '<div class="empty">暂无符合条件的人才</div>';
  return `
    <div style="font-size:11px;color:var(--ink-light);margin-bottom:10px;">A 级以上 · 周末无占用 · 显示前 8 位</div>
    ${candidates.map(t => `
      <div onclick="openDrawer(${t.id})" style="display:flex;align-items:center;padding:8px 0;border-bottom:1px solid var(--line-soft);cursor:pointer;">
        <span class="rating rating-${t.tech_rating || t.quality_rating || t.service_rating}" style="margin-right:12px;">${t.tech_rating || t.quality_rating || t.service_rating}</span>
        <span style="flex:1;font-weight:500;">${t.name}</span>
        <span class="role-badge">${ROLE_NAME[t.role_type]}</span>
        <span style="color:var(--ink-light);font-size:12px;margin-left:12px;font-family:'Cormorant Garamond',serif;">${t.phone}</span>
      </div>
    `).join('')}
  `;
}

function renderRecentActivity(all) {
  // 收集所有"事件"：派单/客诉/联系/试用/创建
  const events = [];
  all.forEach(t => {
    (t.dispatch_records || []).forEach(d => events.push({ date: d.date, type: '派单', desc: `派单 ${t.name}：${d.task || ''}`, talent: t }));
    (t.complaints || []).forEach(c => events.push({ date: c.date, type: c.type, desc: `${t.name}：${c.content || ''}`, talent: t }));
    (t.contact_records || []).forEach(c => events.push({ date: c.date, type: '联系', desc: `联系 ${t.name}${c.replied ? '（已回复）' : '（待回复）'}`, talent: t }));
    if (t.created_at) events.push({ date: t.created_at.slice(0,10), type: '入库', desc: `${t.name} 入库`, talent: t });
  });
  events.sort((a,b) => b.date.localeCompare(a.date));
  const recent = events.slice(0, 10);
  if (!recent.length) return '<div class="empty">暂无活动记录</div>';
  return recent.map(e => `
    <div style="display:flex;padding:8px 0;border-bottom:1px solid var(--line-soft);font-size:13px;cursor:pointer;" onclick="openDrawer(${e.talent.id})">
      <span style="width:90px;color:var(--ink-light);font-family:'Cormorant Garamond',serif;">${e.date}</span>
