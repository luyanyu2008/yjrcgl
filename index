    "age": 数字或 null,
    "phone": "11位手机号或null",
    "phone_conf": "high|medium|low",
    "wechat": "微信号或null",
    "residence": "居住区域,如:雁塔区",
    "role_type": "makeup|dress|photo|retouch|model|anchor|service|null",
    "role_conf": "high|medium|low",
    "job_intention": "全职|兼职|周末|临时|null",
    "available_shifts": ["早班","中班","晚班","全天"](数组),
    "expected_salary": "期望薪资原文描述",
    "experience_years": "新手|1年以内|1-3年|3年以上|null",
    "skills_tags": ["特长1","特长2"](数组,如:会盘发、会跳舞、有摄影经验),
    "personality": "活泼外向|慢热适中|内向安静|null",
    "ai_summary": "用一段话(80-150字)总结此人的核心信息、亮点、需注意的点。包含对方在意的事项、特殊要求、约定事项、禁忌偏好",
    "raw_quotes": "从原对话里摘出最关键的 1-3 句原话(用「」括起来,用 / 分隔)"
  }
]

规则:
1. 如果识别不准或没说,字段填 null,confidence 填 low
2. 多人对话要分开多个对象;只有一个人就返回单元素数组
3. 客户/老板的话不要建档,只为求职者建档
4. 手机号必须是 11 位数字,否则 null
5. expected_salary 保留原文描述,如"6000-8000"、"按场算"、"看情况"
6. ai_summary 一定要写,这是最重要的;包含对方的诉求、性格观察、注意事项
7. 严格输出 JSON 数组,不要任何额外文字、不要 markdown 代码块
8. 若无法识别任何人,返回空数组 []`;

  const userContent = [];
  if (aiInputMode === 'text') {
    userContent.push({ type: 'text', text: '请解析以下聊天内容,提取所有求职者信息:\n\n' + aiTextInput });
  } else {
    userContent.push({ type: 'text', text: '请解析以下聊天截图,提取所有求职者信息。截图按顺序排列:' });
    aiImageList.forEach(img => {
      userContent.push({
        type: 'image',
        source: { type: 'base64', media_type: img.mediaType, data: img.base64 }
      });
    });
  }

  const response = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      model: 'claude-sonnet-4-20250514',
      max_tokens: 4000,
      system: systemPrompt,
      messages: [{ role: 'user', content: userContent }]
    })
  });

  if (!response.ok) {
    const errText = await response.text();
    throw new Error(`AI 接口返回 ${response.status}: ${errText.substring(0,200)}`);
  }

  const data = await response.json();
  const text = data.content.filter(b => b.type === 'text').map(b => b.text).join('');

  // 抽出 JSON
  let jsonStr = text.trim();
  jsonStr = jsonStr.replace(/^```json\s*/i, '').replace(/^```\s*/, '').replace(/```\s*$/, '').trim();
  const startIdx = jsonStr.indexOf('[');
  const endIdx = jsonStr.lastIndexOf(']');
  if (startIdx === -1 || endIdx === -1) throw new Error('AI 返回格式异常,无法提取 JSON');
  jsonStr = jsonStr.substring(startIdx, endIdx + 1);

  const arr = JSON.parse(jsonStr);
  if (!Array.isArray(arr)) throw new Error('AI 返回非数组');
  return arr;
}

