  if (t.role_type === 'makeup') {
    add('年龄', t.age);
    add('意向', t.job_intention);
    add('可上班', t.available_shifts);
    add('期望薪资', t.expected_salary);
    add('从业年限', t.experience_years);
    add('擅长风格', t.makeup_styles);
  } else if (t.role_type === 'photo') {
    add('合作模式', t.cooperation_mode);
    add('接单时段', t.available_time);
    add('擅长风格', t.photo_styles);
    add('熟悉外景', t.familiar_scenes);
    add('自备设备', t.own_equipment);
    add('机身型号', t.camera_body);
    add('常用镜头', t.lenses);
    add('整套道具', t.has_props);
    add('道具清单', t.props_list);
    add('个人优势', t.advantages);
    add('交付时效', t.delivery_time);
    add('期望报价', t.expected_fee);
  } else if (t.role_type === 'retouch') {
    add('合作模式', t.cooperation_mode);
    add('接单时段', t.available_time);
    add('擅长风格', t.retouch_styles);
    add('软件技能', t.software_skills);
    add('出片速度', t.delivery_speed);
    add('个人优势', t.advantages);
    add('报价标准', t.price_standard);
  } else if (t.role_type === 'service') {
    add('意向岗位', t.job_intention);
    add('可上班', t.available_shifts);
    add('熟悉平台', t.platforms);
    add('期望薪资', t.expected_salary);
    if (t.experience) add('经验说明', t.experience);
  } else if (t.role_type === 'dress') {
    add('年龄', t.age);
    add('详细地址', t.detail_address);
    add('通勤时长', t.commute_time);
    add('可入职', t.entry_date);
    add('期望薪资', t.expected_salary);
    add('岗位意向', t.job_intention);
    add('可上班', t.available_shifts);
    add('周末节假日', t.weekend_holiday);
    add('临时顶班', t.emergency_cover);
    add('行业经验', t.industry_exp);
    add('从业年限', t.experience_years);
    add('之前门店', t.previous_store);
    add('熟悉内容', t.dress_skills);
    add('麻利度', t.efficiency_self);
    add('眼里有活', t.proactive);
    add('维护整洁', t.tidiness);
    add('抗压能力', t.pressure);
    if (t.strengths) add('个人特长', t.strengths);
    if (t.weaknesses) add('自身短板', t.weaknesses);
    if (t.other_requirements) add('其他要求', t.other_requirements);
  } else if (t.role_type === 'model') {
    add('性别', t.gender);
    add('年龄', t.age);
    add('身高', t.height ? t.height + ' cm' : '');
    add('体重', t.weight ? t.weight + ' kg' : '');
    add('三围', t.measurements);
    add('穿衣尺码', t.clothing_size);
    add('肤色', t.skin_tone);
    add('通勤', t.commute_time);
    add('可接单', t.available_time);
    add('行业经验', t.industry_exp);
    add('从业时长', t.experience_years);
    add('可接类型', t.shoot_types);
    add('古风仪态', t.pose_ability);
    add('镜头表现', t.camera_ability);
    add('合作形式', t.cooperation_form);
    add('单套报价', t.price_single);
