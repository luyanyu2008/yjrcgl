async function backupAll() {
  const all = await getAllTalents();
  const blob = new Blob([JSON.stringify(all, null, 2)], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `云锦长安人才库_备份_${new Date().toISOString().slice(0,10)}.json`;
  a.click();
  toast('备份已下载');
}

async function restoreAll(e) {
  const file = e.target.files[0];
  if (!file) return;
  if (!confirm('导入会追加到现有数据中，是否继续？')) return;
  const text = await file.text();
  const arr = JSON.parse(text);
  const db = await openDB();
  for (const item of arr) {
    delete item.id;  // 让数据库重新分配
    await new Promise(resolve => {
      const tx = db.transaction(STORE, 'readwrite');
      tx.objectStore(STORE).add(item);
      tx.oncomplete = resolve;
    });
  }
  toast(`已导入 ${arr.length} 条`);
  render();
}

async function clearAll() {
  if (!confirm('确认清空所有数据？此操作不可恢复！请先做备份。')) return;
  if (!confirm('再次确认：真的要清空吗？')) return;
  const db = await openDB();
  const tx = db.transaction(STORE, 'readwrite');
  tx.objectStore(STORE).clear();
  tx.oncomplete = () => { toast('已清空'); render(); };
}

