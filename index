async function batchSaveAI() {
  const all = await getAllTalents();
  let createdCount = 0, updatedCount = 0, skipCount = 0;

  for (let idx = 0; idx < aiParseResults.length; idx++) {
    const r = aiParseResults[idx];
    if (r._skip) { skipCount++; continue; }

    // 从 input 读最新值（用户可能改过）
    const read = (k) => {
      const el = document.getElementById(`ai-f-${idx}-${k}`);
      return el ? el.value : '';
    };

    const name = read('name').trim();
    const phone = read('phone').trim();
    if (!name) { skipCount++; continue; }

    const aiSummary = read('ai_summary').trim();
    const rawQuotes = read('raw_quotes').trim();
    const aiEntry = {
      date: new Date().toISOString().slice(0,10),
      time: new Date().toISOString(),
      mode: aiInputMode,
      summary: aiSummary,
      raw_quotes: rawQuotes,
      raw_input: aiInputMode === 'text' ? aiTextInput.substring(0, 2000) : `[${aiImageList.length} 张图片]`
    };

    // 检查是否已有档案
    let existing = null;
    if (phone && /^1[3-9]\d{9}$/.test(phone)) {
      existing = all.find(t => t.phone === phone && t.blacklist_mark !== '永久拉黑');
    }

    if (existing) {
      // 合并更新:不覆盖原有评价,只追加 AI 备注 + 智能合并新字段
      existing.ai_history = existing.ai_history || [];
      existing.ai_history.push(aiEntry);
      existing.ai_notes = (existing.ai_notes ? existing.ai_notes + '\n\n' : '') +
        `[${aiEntry.date} AI 更新]\n${aiSummary}` + (rawQuotes ? `\n原话:${rawQuotes}` : '');
      // 智能合并:空字段才覆盖
      if (!existing.wechat && read('wechat')) existing.wechat = read('wechat');
      if (!existing.residence && read('residence')) existing.residence = read('residence');
      if (!existing.expected_salary && read('expected_salary')) existing.expected_salary = read('expected_salary');
      if (!existing.age && read('age')) existing.age = read('age');
      existing.updated_at = new Date().toISOString();
      await updateTalent(existing);
      updatedCount++;
    } else {
      // 新建
      const role = read('role_type') || r.role_type || 'service';
      const newTalent = {
        role_type: role,
        name,
        phone,
        wechat: read('wechat'),
        gender: read('gender'),
        age: read('age'),
        residence: read('residence'),
        job_intention: read('job_intention'),
        available_shifts: read('available_shifts').split(/[、,，]/).map(s=>s.trim()).filter(Boolean),
        expected_salary: read('expected_salary'),
        experience_years: read('experience_years'),
        personality_type: read('personality'),
        self_recommend: read('skills_tags'),
        ai_notes: `[${aiEntry.date} AI 录入]\n${aiSummary}` + (rawQuotes ? `\n原话:${rawQuotes}` : ''),
        ai_history: [aiEntry],
        status: role === 'service' ? '在职' : role === 'model' ? '待试拍' : role === 'anchor' ? '待试播' : '待复试',
        blacklist_mark: '正常',
        work_count: 0,
        complaint_count: 0,
        created_at: new Date().toISOString(),
        ai_created: true
      };
      await saveNewTalent(newTalent);
      createdCount++;
    }
  }

  // 清空当前批
  aiParseResults = [];
  aiTextInput = '';
  aiImageList = [];

  toast(`✓ 录入完成 · 新建 ${createdCount} · 更新 ${updatedCount}${skipCount?' · 跳过 '+skipCount:''}`);
  setTimeout(() => {
    currentView = 'all';
    refreshNav();
    render();
  }, 1200);
}

async function saveNewTalent(data) {
  const db = await openDB();
  return new Promise((resolve, reject) => {
    const tx = db.transaction(STORE, 'readwrite');
    const req = tx.objectStore(STORE).add(data);
    req.onsuccess = () => resolve(req.result);
    req.onerror = e => reject(e);
  });
}

