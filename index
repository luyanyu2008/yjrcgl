async function saveTalentChanges() {
  const t = currentTalent;
  const role = t.role_type;
  const ratingKey = role === 'retouch' ? 'quality_rating' : role === 'service' ? 'service_rating' : 'tech_rating';
  const scoreKey = role === 'photo' ? 'composition_score' : 'trial_score';

  t[ratingKey] = document.getElementById('ed-rating').value;
  const stars = document.querySelectorAll('#star-group .star.on').length;
  t[scoreKey] = stars;
  t.status = document.getElementById('ed-status').value;
  t.blacklist_mark = document.getElementById('ed-blacklist').value;
  t.blacklist_reason = document.getElementById('ed-blacklist-reason').value;
  t.work_count = +document.getElementById('ed-work').value || 0;
  t.complaint_count = +document.getElementById('ed-complaint').value || 0;
  t.re_bookable = document.getElementById('ed-rebookable').value;
  t.pros_cons = document.getElementById('ed-pros-cons').value;

  if (role === 'makeup') {
    t.efficiency = document.getElementById('ed-efficiency').value;
    t.attitude = document.getElementById('ed-attitude').value;
    t.hygiene = document.getElementById('ed-hygiene').value;
  } else if (role === 'photo') {
    t.retouch_ability = document.getElementById('ed-retouch-ability').value;
    t.cooperation_attitude = document.getElementById('ed-cooperation').value;
    t.punctuality = document.getElementById('ed-punctuality').value;
    t.no_show_count = +document.getElementById('ed-no-show').value || 0;
  } else if (role === 'retouch') {
    t.response_speed = document.getElementById('ed-response').value;
    t.revision_attitude = document.getElementById('ed-revision').value;
    t.delivery_compliance = document.getElementById('ed-delivery').value;
  } else if (role === 'service') {
    t.response_speed = document.getElementById('ed-response').value;
    t.professionalism = document.getElementById('ed-professional').value;
    t.conversion_rate = document.getElementById('ed-conversion').value;
  } else if (role === 'dress') {
    t.reception_ability = document.getElementById('ed-reception').value;
    t.tidy_speed = document.getElementById('ed-tidy-speed').value;
    t.image_temperament = document.getElementById('ed-image').value;
    t.aesthetic = document.getElementById('ed-aesthetic').value;
  } else if (role === 'model') {
    t.hanfu_fit = document.getElementById('ed-hanfu-fit').value;
    t.cooperation_attitude = document.getElementById('ed-model-coop').value;
    t.punctuality = document.getElementById('ed-model-punctual').value;
    t.no_show_count = +document.getElementById('ed-no-show').value || 0;
    t.mutual_promise = document.getElementById('ed-mutual-promise').value;
    t.portrait_rights = document.getElementById('ed-portrait').value;
  } else if (role === 'anchor') {
    t.real_speech = document.getElementById('ed-real-speech').value;
    t.real_conversion = document.getElementById('ed-real-conv').value;
    t.emotion_stable = document.getElementById('ed-emotion').value;
    t.avg_sales = document.getElementById('ed-avg-sales').value;
    t.punctuality = document.getElementById('ed-anchor-punctual').value;
  }

  await updateTalent(t);
  toast('保存成功');
  closeDrawer();
  renderList();
}

