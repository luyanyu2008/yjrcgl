<script>
/* ============== 数据库 ============== */
const DB_NAME = 'yunjin_talents';
const STORE = 'talents';

function openDB() {
  return new Promise((resolve, reject) => {
    const req = indexedDB.open(DB_NAME, 1);
    req.onupgradeneeded = e => {
      const db = e.target.result;
      if (!db.objectStoreNames.contains(STORE)) {
        const store = db.createObjectStore(STORE, { keyPath: 'id', autoIncrement: true });
        store.createIndex('phone', 'phone', { unique: false });
        store.createIndex('role_type', 'role_type', { unique: false });
      }
    };
    req.onsuccess = e => resolve(e.target.result);
    req.onerror = e => reject(e);
  });
}

async function getAllTalents() {
  const db = await openDB();
  return new Promise(resolve => {
    const tx = db.transaction(STORE, 'readonly');
    const req = tx.objectStore(STORE).getAll();
    req.onsuccess = () => resolve(req.result || []);
    req.onerror = () => resolve([]);
  });
}

async function updateTalent(data) {
  const db = await openDB();
  return new Promise((resolve, reject) => {
    const tx = db.transaction(STORE, 'readwrite');
    const req = tx.objectStore(STORE).put(data);
    req.onsuccess = () => resolve();
    req.onerror = e => reject(e);
  });
}

async function deleteTalent(id) {
  const db = await openDB();
  return new Promise(resolve => {
    const tx = db.transaction(STORE, 'readwrite');
    tx.objectStore(STORE).delete(id);
    tx.oncomplete = () => resolve();
  });
}

/* ============== 角色映射 ============== */
const ROLE_NAME = {
  makeup: '妆造师', dress: '礼服师', photo: '摄影师', retouch: '修图师',
  model: '模特', anchor: '主播', service: '客服'
};

/* ============== 工具：自动评级算法 ============== */
function calcAutoRating(t) {
  // 基础技术分（管理员主观打分） + 上岗经验 - 客诉 - 放鸽子
  const baseScore = t.trial_score || t.composition_score || 5;
  let score = baseScore * 5;        // 基础分占 50%
  const workBonus = Math.min(t.work_count || 0, 20) * 1.25;  // 上岗经验最多加 25 分
  const complaintPenalty = (t.complaint_count || 0) * 5;
  const noShowPenalty = (t.no_show_count || 0) * 8;
  score = score + workBonus - complaintPenalty - noShowPenalty;
  score = Math.max(0, Math.min(100, score));
  let rating = 'C';
  if (score >= 85) rating = 'S';
  else if (score >= 70) rating = 'A';
  else if (score >= 50) rating = 'B';
  return { score: Math.round(score), rating };
}

/* ============== 主渲染 ============== */
let currentView = 'dashboard';
let currentFilters = { keyword: '', rating: '', status: '', style: '', availableDate: '' };

document.querySelectorAll('.nav-item').forEach(item => {
  item.addEventListener('click', () => {
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    item.classList.add('active');
    currentView = item.dataset.view;
    render();
  });
});

async function render() {
  await updateCounts();
  if (currentView === 'qr') return renderQR();
  if (currentView === 'settings') return renderSettings();
  if (currentView === 'dashboard') return renderDashboard();
  if (currentView === 'followup') return renderFollowup();
  if (currentView === 'referrers') return renderReferrers();
  if (currentView === 'ai-import') return renderAIImport();
  renderList();
}

async function updateCounts() {
  const all = await getAllTalents();
  document.getElementById('count-all').textContent = all.length;
  document.getElementById('count-makeup').textContent = all.filter(t => t.role_type === 'makeup').length;
  document.getElementById('count-dress').textContent = all.filter(t => t.role_type === 'dress').length;
  document.getElementById('count-model').textContent = all.filter(t => t.role_type === 'model').length;
  document.getElementById('count-anchor').textContent = all.filter(t => t.role_type === 'anchor').length;
  document.getElementById('count-photo').textContent = all.filter(t => t.role_type === 'photo').length;
  document.getElementById('count-retouch').textContent = all.filter(t => t.role_type === 'retouch').length;
  document.getElementById('count-service').textContent = all.filter(t => t.role_type === 'service').length;
  document.getElementById('count-block').textContent = all.filter(t => t.blacklist_mark && t.blacklist_mark !== '正常').length;
  // 待跟进 = 有标记"待跟进" + 联系未回复超 3 天 + 互免承诺未交付 + 欠款未结
  const followupCount = all.filter(t => isNeedFollowup(t)).length;
  const followupEl = document.getElementById('count-followup');
  if (followupEl) followupEl.textContent = followupCount;
}

function isNeedFollowup(t) {
  // 1) 手动标记的待跟进
  if ((t.flags || []).includes('⏰ 待跟进')) return true;
  // 2) 联系未回复超 3 天
  const cr = t.contact_records || [];
  if (cr.length) {
    const last = cr[cr.length - 1];
    if (!last.replied && last.date) {
      const diff = (Date.now() - new Date(last.date).getTime()) / (1000*60*60*24);
      if (diff > 3) return true;
    }
  }
  // 3) 互免承诺未交付
  if (t.role_type === 'model' && t.mutual_promise && /未交付|未给|欠/.test(t.mutual_promise)) return true;
  // 4) 欠款未结
  const pr = t.payment_records || [];
  if (pr.some(p => !p.settled && Number(p.amount) > 0)) return true;
  return false;
}

async function renderList() {
  const all = await getAllTalents();
  let list = [...all];

  if (currentView === 'blacklist') {
    list = list.filter(t => t.blacklist_mark && t.blacklist_mark !== '正常');
  } else if (currentView !== 'all') {
    list = list.filter(t => t.role_type === currentView);
  }

  // 应用筛选
  if (currentFilters.keyword) {
    const k = currentFilters.keyword.toLowerCase();
    list = list.filter(t =>
      (t.name || '').toLowerCase().includes(k) ||
      (t.phone || '').includes(k) ||
      (t.wechat || '').toLowerCase().includes(k)
    );
  }
  if (currentFilters.rating) {
    list = list.filter(t => (t.tech_rating || t.quality_rating || t.service_rating) === currentFilters.rating);
  }
  if (currentFilters.status) {
    list = list.filter(t => t.status === currentFilters.status);
  }
  if (currentFilters.style) {
    list = list.filter(t => {
      const arr = [].concat(t.makeup_styles||[], t.photo_styles||[], t.retouch_styles||[], t.dress_skills||[]);
      return arr.includes(currentFilters.style);
    });
  }
  if (currentFilters.availableDate) {
    list = list.filter(t => {
      const busy = t.calendar_busy || [];
      return !busy.includes(currentFilters.availableDate);
    });
  }

  // 评级排序
  const ratingOrder = { 'S': 0, 'A': 1, 'B': 2, 'C': 3, '': 4 };
  list.sort((a,b) => {
    const ra = ratingOrder[a.tech_rating || a.quality_rating || a.service_rating || ''];
    const rb = ratingOrder[b.tech_rating || b.quality_rating || b.service_rating || ''];
    return ra - rb;
  });

  // 顶部 stats
  const stats = {
    total: all.length,
    sLevel: all.filter(t => ['S'].includes(t.tech_rating || t.quality_rating || t.service_rating)).length,
    pending: all.filter(t => t.status === '待复试').length,
    blacklist: all.filter(t => t.blacklist_mark === '永久拉黑').length,
    weekend: countWeekendAvailable(all)
  };

  document.getElementById('main').innerHTML = `
    <div class="page-head">
      <div class="page-title">
        ${currentView === 'all' ? '全部人才' :
          currentView === 'blacklist' ? '黑名单管理' :
          ROLE_NAME[currentView]}
        <small>${list.length} 位</small>
      </div>
      <div class="actions">
        <button class="btn" onclick="exportExcel()">导出 Excel</button>
        <button class="btn btn-dark" onclick="window.open('人才录入.html', '_blank')">查看应聘端</button>
      </div>
    </div>

    <div class="dashboard">
      <div class="stat-card">
        <div class="stat-label">人 才 总 数</div>
        <div class="stat-value">${stats.total}<span class="unit">位</span></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">S 级 顶 配</div>
        <div class="stat-value" style="color:var(--rouge);">${stats.sLevel}<span class="unit">位</span></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">待 复 试</div>
        <div class="stat-value" style="color:var(--orange);">${stats.pending}<span class="unit">位</span></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">本 周 末 可 约</div>
        <div class="stat-value" style="color:var(--green);">${stats.weekend}<span class="unit">位</span></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">黑 名 单</div>
        <div class="stat-value" style="color:var(--ink);">${stats.blacklist}<span class="unit">位</span></div>
      </div>
    </div>

    <div class="filters">
      <div class="filter-item">
        <label>搜索</label>
        <input type="text" placeholder="姓名 / 手机 / 微信" id="f-keyword" value="${currentFilters.keyword}">
      </div>
      <div class="filter-item">
        <label>评级</label>
        <select id="f-rating">
          <option value="">全部</option>
          <option value="S" ${currentFilters.rating==='S'?'selected':''}>S</option>
          <option value="A" ${currentFilters.rating==='A'?'selected':''}>A</option>
          <option value="B" ${currentFilters.rating==='B'?'selected':''}>B</option>
          <option value="C" ${currentFilters.rating==='C'?'selected':''}>C</option>
        </select>
      </div>
      <div class="filter-item">
        <label>状态</label>
        <select id="f-status">
          <option value="">全部</option>
          <option value="待复试">待复试</option>
          <option value="已录用">已录用</option>
          <option value="兼职合作">兼职合作</option>
          <option value="长期签约">长期签约</option>
          <option value="偶尔合作">偶尔合作</option>
          <option value="已离职">已离职</option>
          <option value="拉黑">拉黑</option>
        </select>
      </div>
      <div class="filter-item">
        <label>擅长</label>
        <select id="f-style">
          <option value="">全部</option>
          <optgroup label="妆造">
            <option>唐风</option><option>宋制</option><option>明制</option>
            <option>清冷风</option><option>少女感</option><option>古风新娘</option>
          </optgroup>
          <optgroup label="摄影">
            <option>古风氛围感</option><option>情侣</option><option>外景</option>
          </optgroup>
          <optgroup label="礼服">
            <option>汉服形制</option><option>礼服搭配</option><option>尺码适配</option>
            <option>穿搭整理</option><option>简单盘发</option><option>简单化妆</option>
          </optgroup>
        </select>
      </div>
      <div class="filter-item">
        <label>当日可约</label>
        <input type="date" id="f-date" value="${currentFilters.availableDate}">
      </div>
      <button class="btn" onclick="applyFilters()">筛选</button>
      <button class="btn" onclick="clearFilters()">清除</button>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>姓名 / 联系方式</th>
            <th>岗位</th>
            <th>评级</th>
            <th>擅长 / 标签</th>
            <th>状态</th>
            <th>上岗</th>
            <th>客诉</th>
            <th>登记时间</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          ${list.length === 0 ? `
            <tr><td colspan="9" class="empty">暂无数据</td></tr>
          ` : list.map(t => renderRow(t)).join('')}
        </tbody>
      </table>
    </div>
  `;

  document.getElementById('f-rating').addEventListener('change', applyFilters);
  document.getElementById('f-status').addEventListener('change', applyFilters);
  document.getElementById('f-style').addEventListener('change', applyFilters);
  document.getElementById('f-date').addEventListener('change', applyFilters);
  document.getElementById('f-keyword').addEventListener('input', e => {
    currentFilters.keyword = e.target.value;
    clearTimeout(window.__kwTimer);
    window.__kwTimer = setTimeout(() => renderList(), 200);
  });
}

function countWeekendAvailable(all) {
  const now = new Date();
  const dow = now.getDay();
  const sat = new Date(now); sat.setDate(now.getDate() + ((6 - dow + 7) % 7));
  const sun = new Date(sat); sun.setDate(sat.getDate() + 1);
  const fmt = d => d.toISOString().slice(0,10);
  return all.filter(t => {
    const busy = t.calendar_busy || [];
    return !busy.includes(fmt(sat)) && !busy.includes(fmt(sun));
  }).length;
}

function applyFilters() {
  currentFilters.keyword = document.getElementById('f-keyword').value;
  currentFilters.rating = document.getElementById('f-rating').value;
  currentFilters.status = document.getElementById('f-status').value;
  currentFilters.style = document.getElementById('f-style').value;
  currentFilters.availableDate = document.getElementById('f-date').value;
  renderList();
}

function clearFilters() {
  currentFilters = { keyword: '', rating: '', status: '', style: '', availableDate: '' };
  renderList();
}

function renderRow(t) {
  const rating = t.tech_rating || t.quality_rating || t.service_rating || '';
  const ratingClass = rating ? `rating-${rating}` : 'rating-none';
  const styles = [].concat(t.makeup_styles||[], t.photo_styles||[], t.retouch_styles||[], t.platforms||[], t.dress_skills||[], t.shoot_types||[], t.anchor_categories||[], t.image_style||[]).slice(0,3);
  const statusClass =
    t.blacklist_mark === '永久拉黑' ? 'status-block' :
    t.status === '已录用' || t.status === '长期签约' ? 'status-good' :
    t.status === '待复试' ? 'status-warn' :
    t.status === '拉黑' || t.status === '已离职' ? 'status-bad' : 'status-default';

  return `
    <tr onclick="openDrawer(${t.id})" style="cursor:pointer;">
      <td>
        <div class="name-cell">
          ${t.selfie_url ?
            `<img class="avatar" src="${t.selfie_url}">` :
            `<span class="avatar">${(t.name || '?').slice(0,1)}</span>`}
          <div class="name-info">
            <span class="name">${t.name || '-'}</span>
            <span class="phone">${t.phone || ''}</span>
          </div>
        </div>
      </td>
      <td><span class="role-badge">${ROLE_NAME[t.role_type] || '-'}</span></td>
      <td><span class="rating ${ratingClass}">${rating || '-'}</span></td>
      <td><div class="styles-tags">${styles.map(s => `<span class="style-tag">${s}</span>`).join('') || '-'}</div></td>
      <td><span class="status-tag ${statusClass}">${t.status || '-'}</span></td>
      <td style="font-family:'Cormorant Garamond',serif;">${t.work_count || 0}</td>
      <td style="font-family:'Cormorant Garamond',serif;color:${(t.complaint_count||0)>0?'var(--rouge)':'var(--ink-light)'};">${t.complaint_count || 0}</td>
      <td style="color:var(--ink-light);font-size:12px;">${formatDate(t.created_at)}</td>
      <td><span style="color:var(--ink-light);">›</span></td>
    </tr>
  `;
}

function formatDate(iso) {
  if (!iso) return '-';
  const d = new Date(iso);
  return `${d.getMonth()+1}/${d.getDate()}`;
}

/* ============== 抽屉详情 ============== */
let currentTalent = null;

async function openDrawer(id) {
  const all = await getAllTalents();
  currentTalent = all.find(t => t.id === id);
  if (!currentTalent) return;
  document.getElementById('drawer-title').textContent = `${currentTalent.name} · ${ROLE_NAME[currentTalent.role_type]}`;
  renderDrawerBody();
  document.getElementById('drawer-mask').classList.add('show');
  document.getElementById('drawer').classList.add('show');
}

function closeDrawer() {
  document.getElementById('drawer-mask').classList.remove('show');
  document.getElementById('drawer').classList.remove('show');
  currentTalent = null;
}
