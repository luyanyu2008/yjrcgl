async function saveComplaint() {
  const t = currentTalent;
  if (!t.complaints) t.complaints = [];
  const type = document.getElementById('cp-type').value;
  t.complaints.push({
    type: type,
    date: document.getElementById('cp-date').value,
    customer: document.getElementById('cp-customer').value,
    content: document.getElementById('cp-content').value,
    handling: document.getElementById('cp-handling').value
  });
  if (type === '客诉') t.complaint_count = (t.complaint_count || 0) + 1;
  await updateTalent(t);
  closeModal();
  renderDrawerBody();
  toast('已添加');
}

async function delComplaint(idx) {
  if (!confirm('删除这条记录？')) return;
  const t = currentTalent;
  const item = t.complaints[idx];
  if (item.type === '客诉') t.complaint_count = Math.max(0, (t.complaint_count || 0) - 1);
  t.complaints.splice(idx, 1);
  await updateTalent(t);
  renderDrawerBody();
}

